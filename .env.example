# Frontend (Vite) — safe to expose in the client bundle
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Optional: PostHog project API key (browser analytics)
# VITE_POSTHOG_KEY=

# Optional: Stripe publishable key (reserved for future client-side Stripe.js; Checkout uses Edge Functions only.)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Do NOT put OpenAI keys here — set OPENAI_API_KEY as a secret on the Edge Function instead (see README).
# Stripe (Edge Functions — set as Supabase secrets, never in Vite):
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_PRO_MONTHLY=price_...
# SERVICE_ROLE_KEY=...   (required for stripe-webhook; use a non-SUPABASE_ secret name — set via `supabase secrets set`)
# PUBLIC_SITE_URL=https://sclearn.app   (optional; defaults to sclearn.app for checkout URLs)
